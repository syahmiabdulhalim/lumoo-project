# Copy this file to .env and fill in real values
# .env is gitignored — never commit real secrets

RESEND_API_KEY=re_your_api_key_here
ENCRYPTION_KEY=base64_32byte_key_here

# ModemPay — https://merchant.modempay.com → Developers → API Keys
MODEMPAY_API_KEY=sk_test_your_key_here
MODEMPAY_WEBHOOK_SECRET=your_webhook_secret_here

# Cache — set to "simple" for local dev (no Redis needed), "redis" for Docker/production
SPRING_CACHE_TYPE=simple

# Redis — only needed when SPRING_CACHE_TYPE=redis
# REDIS_HOST=localhost
# REDIS_PORT=6379
